      உங்கள் order கிடைத்தது! 🙏<br>
      நாங்கள் confirm செய்வோம்.<br>
      <span class="del-highlight">🕐 Delivery: 7:30 PM – 9:30 PM</span>
    </div>
    <a id="wa-confirm" href="#" target="_blank" class="s-wa">💬 WhatsApp-ல் Order அனுப்பு</a>
    <button class="s-close" onclick="closeSuccess()">Done ✓</button>
  </div>
</div>

<div class="loading" id="loading"><div class="spinner"></div><p>Order அனுப்புகிறோம்... ⏳</p></div>

<div class="footer">
  <p>Made with ❤️ for KRK's Kitchen</p>
  <p style="margin-top:6px;">Call: <a href="tel:+916384991641">63849 91641</a></p>
</div>

<script>
const CONFIG = {
  shopName: "KRK's Kitchen",
  phone: "6384991641",
  upiId: "jaiisonly@okicici",
  deliveryStart: "7:30 PM",
  deliveryEnd: "9:30 PM",
  orderCutoff: "5:00 PM",
  googleScriptURL: "https://script.google.com/macros/s/AKfycbyKOhwFRJ5lE3yWwzPyPjQUkUooyhyGVbENorLbmnlfAwq2eAktn8y4cT652oKP88k4HQ/exec",
};

document.getElementById('menu-date-badge').textContent = new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short',weekday:'short'});

let cart={}, payMethod='', custLoc=null;

async function loadMenu(){
  try{
    const res=await fetch(CONFIG.googleScriptURL+'?action=getMenu');
    const data=await res.json();
    if(data.menu&&data.menu.length>0) renderMenu(data.menu);
    else loadDemoMenu();
  }catch(e){loadDemoMenu();}
}

function loadDemoMenu(){
  renderMenu([
    {id:1,name:'Meals (Full)',price:80,emoji:'🍱',desc:'Rice, sambar, 2 veg, papad',type:'veg'},
    {id:2,name:'Chicken Gravy',price:120,emoji:'🍗',desc:'Spicy chicken curry + rice',type:'nonveg'},
    {id:3,name:'Chapati Set',price:60,emoji:'🫓',desc:'3 chapati + veg kurma',type:'veg'},
    {id:4,name:'Egg Rice',price:70,emoji:'🍳',desc:'Egg fried rice + gravy',type:'nonveg'},
  ]);
}

function renderMenu(items){
  const grid=document.getElementById('menu-grid');
  grid.innerHTML='';
  items.forEach(item=>{
    const card=document.createElement('div');
    card.className='food-card'; card.id='card-'+item.id;
    card.innerHTML=`<div class="food-check">✓</div><div class="food-img">${item.emoji}<span class="veg-dot ${item.type||'veg'}"></span></div><div class="food-info"><div class="food-name">${item.name}</div>${item.desc?`<div class="food-desc">${item.desc}</div>`:''}<div class="food-price">₹${item.price}</div><div class="qty-sel"><button class="qty-btn" onclick="chgQty(event,${item.id},-1)">−</button><span class="qty-num" id="qty-${item.id}">1</span><button class="qty-btn" onclick="chgQty(event,${item.id},1)">+</button></div></div>`;
    card.onclick=()=>toggleItem(item.id,item.price,item.name);
    grid.appendChild(card);
  });
}

function toggleItem(id,price,name){
  if(cart[id]){delete cart[id];document.getElementById('card-'+id).classList.remove('selected');document.getElementById('qty-'+id).textContent='1';}
  else{cart[id]={name,price,qty:1};document.getElementById('card-'+id).classList.add('selected');}
  updateCart();
}
function chgQty(e,id,d){e.stopPropagation();if(!cart[id])return;cart[id].qty=Math.max(1,cart[id].qty+d);document.getElementById('qty-'+id).textContent=cart[id].qty;updateCart();}

function updateCart(){
  const keys=Object.keys(cart);
  const total=keys.reduce((s,k)=>s+cart[k].price*cart[k].qty,0);
  const items=keys.reduce((s,k)=>s+cart[k].qty,0);
  document.getElementById('cart-bar').classList.toggle('show',keys.length>0);
  document.getElementById('cart-count').textContent=items+' item'+(items>1?'s':'');
  document.getElementById('cart-total').textContent='Total: ₹'+total;
  document.getElementById('order-summary').classList.toggle('show',keys.length>0);
  document.getElementById('sum-items').innerHTML=keys.map(k=>`<div class="sum-item"><span>${cart[k].name} × ${cart[k].qty}</span><span>₹${cart[k].price*cart[k].qty}</span></div>`).join('');
  document.getElementById('sum-total').textContent='₹'+total;
  document.getElementById('gpay-amount').textContent='₹'+total;
  document.getElementById('gpay-link').href=`upi://pay?pa=${CONFIG.upiId}&pn=${encodeURIComponent(CONFIG.shopName)}&am=${total}&cu=INR&tn=DinnerOrder`;
}

function getLocation(){
  const btn=document.getElementById('loc-btn');
  btn.textContent='⏳ Detecting...'; btn.disabled=true;
  if(!navigator.geolocation){showLocErr('GPS இல்லை');return;}
  navigator.geolocation.getCurrentPosition(
    pos=>{
      const lat=pos.coords.latitude.toFixed(6),lng=pos.coords.longitude.toFixed(6),acc=Math.round(pos.coords.accuracy);
      custLoc={lat,lng,acc};
      document.getElementById('loc-box').classList.add('got');
      document.getElementById('loc-title').textContent='✅ Location கிடைத்தது!';
      document.getElementById('loc-sub').textContent='Accuracy: ±'+acc+'m';
      document.getElementById('loc-coords').textContent='📍 '+lat+', '+lng;
      document.getElementById('loc-map-link').innerHTML=`<a href="https://maps.google.com/?q=${lat},${lng}" target="_blank">🗺️ Maps-ல் verify பண்ணுங்கள்</a>`;
      btn.textContent='✅ Got! Click to update'; btn.classList.add('got'); btn.disabled=false;
    },
    err=>{
      let msg='❌ Location கிடைக்கவில்லை';
      if(err.code===1)msg='❌ Permission deny! Settings-ல் allow பண்ணுங்கள்';
      showLocErr(msg);
    },
    {enableHighAccuracy:true,timeout:15000,maximumAge:0}
  );
}
function showLocErr(msg){
  document.getElementById('loc-box').classList.add('err');
  document.getElementById('loc-title').textContent=msg;
  const btn=document.getElementById('loc-btn');
  btn.textContent='🔄 Retry'; btn.classList.remove('got'); btn.disabled=false; custLoc=null;
}

function selPay(m){payMethod=m;document.getElementById('pay-gpay').classList.toggle('selected',m==='gpay');document.getElementById('pay-cod').classList.toggle('selected',m==='cod');document.getElementById('gpay-sec').classList.toggle('show',m==='gpay');}
function scrollToForm(){document.getElementById('order-form-section').scrollIntoView({behavior:'smooth',block:'start'});}

async function submitOrder(){
  const name=document.getElementById('cust-name').value.trim();
  const phone=document.getElementById('cust-phone').value.trim();
  const address=document.getElementById('cust-address').value.trim();
  const note=document.getElementById('cust-note').value.trim();
  if(!Object.keys(cart).length){alert('❌ Food select பண்ணுங்கள்!');return;}
  if(!name){alert('❌ பெயர் enter பண்ணுங்கள்!');document.getElementById('cust-name').focus();return;}
  if(!phone||phone.length!==10){alert('❌ Valid 10-digit phone!');document.getElementById('cust-phone').focus();return;}
  if(!address){alert('❌ Address enter பண்ணுங்கள்!');document.getElementById('cust-address').focus();return;}
  if(!custLoc){alert('❌ GPS Location அவசியம்!');document.getElementById('loc-btn').scrollIntoView({behavior:'smooth'});return;}
  if(!payMethod){alert('❌ Payment method select பண்ணுங்கள்!');return;}

  const total=Object.keys(cart).reduce((s,k)=>s+cart[k].price*cart[k].qty,0);
  const items=Object.keys(cart).map(k=>`${cart[k].name}×${cart[k].qty}`).join(', ');
  const orderId='ORD'+Date.now().toString().slice(-6);
  const orderTime=new Date().toLocaleString('en-IN',{timeZone:'Asia/Kolkata'});
  const mapsLink=`https://maps.google.com/?q=${custLoc.lat},${custLoc.lng}`;
  const mapsNav=`https://www.google.com/maps/dir/?api=1&destination=${custLoc.lat},${custLoc.lng}`;

  const orderData={orderId,orderTime,name,phone,address,items,total,payment:payMethod.toUpperCase(),note:note||'-',latitude:custLoc.lat,longitude:custLoc.lng,accuracy:custLoc.acc,mapsLink,mapsNav,deliveryWindow:'7:30 PM – 9:30 PM',status:'PENDING'};

  document.getElementById('loading').classList.add('show');
  document.getElementById('submit-btn').disabled=true;
  try{await fetch(CONFIG.googleScriptURL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(orderData)});}catch(e){}
  document.getElementById('loading').classList.remove('show');

  document.getElementById('s-order-id').textContent='Order #'+orderId;
  const waMsg=`🍱 *New Dinner Order #${orderId}*\n👤 ${name} | 📱 ${phone}\n🍽️ ${items}\n💰 ₹${total} | 💳 ${payMethod.toUpperCase()}\n🏠 ${address}\n📍 Location: ${mapsLink}\n🗺️ Navigate: ${mapsNav}\n🕐 Delivery: 7:30 PM – 9:30 PM\n📝 Note: ${note||'None'}\n⏰ ${orderTime}`;
  document.getElementById('wa-confirm').href=`https://wa.me/916384991641?text=${encodeURIComponent(waMsg)}`;
  document.getElementById('success-screen').classList.add('show');
}

function closeSuccess(){
  document.getElementById('success-screen').classList.remove('show');
  document.getElementById('submit-btn').disabled=false;
  cart={}; payMethod=''; custLoc=null;
  document.querySelectorAll('.food-card').forEach(c=>c.classList.remove('selected'));
  document.querySelectorAll('.qty-num').forEach(q=>q.textContent='1');
  ['order-summary','cart-bar','gpay-sec'].forEach(id=>document.getElementById(id).classList.remove('show'));
  ['pay-gpay','pay-cod'].forEach(id=>document.getElementById(id).classList.remove('selected'));
  ['cust-name','cust-phone','cust-note','cust-address'].forEach(id=>document.getElementById(id).value='');
  const box=document.getElementById('loc-box'); box.classList.remove('got','err');
  document.getElementById('loc-title').textContent='Location share பண்ணுங்கள்';
  document.getElementById('loc-sub').textContent='Delivery boy கண்டுபிடிக்க உதவும் 🛵';
  document.getElementById('loc-coords').textContent=''; document.getElementById('loc-map-link').innerHTML='';
  const btn=document.getElementById('loc-btn'); btn.textContent='📍 Get My Location'; btn.classList.remove('got'); btn.disabled=false;
  window.scrollTo({top:0,behavior:'smooth'});
}

loadMenu();
</script>
</body>
