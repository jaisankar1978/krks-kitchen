<!DOCTYPE html>
<html lang="ta">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🍱 KRK's Kitchen</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Noto+Sans+Tamil:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{--orange:#FF6B00;--yellow:#FFD700;--green:#25D366;--gpay:#4285F4;--bg:#FFF8F0;--dark:#1A0A00;--shadow:0 4px 20px rgba(255,107,0,0.15);}
  *{margin:0;padding:0;box-sizing:border-box;}
  body{font-family:'Poppins','Noto Sans Tamil',sans-serif;background:var(--bg);color:var(--dark);min-height:100vh;}

  .header{background:linear-gradient(135deg,var(--orange),#FF9A00);padding:18px 16px 24px;text-align:center;position:relative;overflow:hidden;}
  .header::before{content:'';position:absolute;top:-40px;right:-40px;width:150px;height:150px;background:rgba(255,255,255,0.1);border-radius:50%;}
  .header h1{font-size:26px;font-weight:800;color:white;text-shadow:0 2px 8px rgba(0,0,0,0.2);position:relative;}
  .header .tagline{color:rgba(255,255,255,0.9);font-size:12px;margin-top:4px;position:relative;}
  .call-btn{display:inline-flex;align-items:center;gap:6px;background:white;color:var(--orange);font-weight:700;font-size:13px;padding:9px 18px;border-radius:50px;text-decoration:none;margin-top:12px;box-shadow:0 4px 15px rgba(0,0,0,0.2);animation:pulse 2s infinite;position:relative;}
  @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}

  .delivery-banner{background:#1C0A00;padding:16px;display:flex;align-items:center;gap:14px;}
  .del-icon{font-size:34px;}
  .del-info{flex:1;}
  .del-info .del-title{font-size:13px;font-weight:700;color:white;}
  .del-info .del-note{font-size:11px;color:rgba(255,255,255,0.65);margin-top:3px;line-height:1.5;}
  .del-timebox{background:var(--yellow);border-radius:12px;padding:10px 14px;text-align:center;min-width:90px;}
  .del-timebox .del-time{font-size:15px;font-weight:800;color:#7A3000;line-height:1.2;}
  .del-timebox .del-label{font-size:9px;font-weight:700;color:#A05000;margin-top:2px;}

  .last-order-strip{background:#FFF3CD;padding:10px 16px;display:flex;align-items:center;gap:8px;border-bottom:2px solid #FFD700;}
  .last-order-strip .lo-icon{font-size:18px;}
  .last-order-strip .lo-text{font-size:12px;font-weight:700;color:#7A3000;flex:1;}
  .last-order-strip .lo-time{font-size:11px;font-weight:800;color:var(--orange);background:white;padding:4px 10px;border-radius:50px;}

  .marquee-bar{background:var(--yellow);padding:7px 0;overflow:hidden;white-space:nowrap;}
  .marquee-bar span{display:inline-block;animation:marquee 18s linear infinite;font-size:12px;font-weight:600;color:#7A3000;padding-right:80px;}
  @keyframes marquee{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}

  .section-title{font-size:17px;font-weight:800;color:var(--orange);padding:18px 16px 8px;display:flex;align-items:center;justify-content:space-between;}
  .menu-date-badge{font-size:11px;font-weight:600;color:#888;background:#EEE;padding:3px 10px;border-radius:50px;}
  .menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:0 12px 16px;}
  .no-menu{margin:0 12px 16px;background:white;border-radius:16px;padding:30px;text-align:center;box-shadow:var(--shadow);}
  .no-menu .nm-icon{font-size:48px;}
  .no-menu .nm-title{font-size:15px;font-weight:700;color:#555;margin-top:10px;}
  .no-menu .nm-sub{font-size:12px;color:#888;margin-top:6px;line-height:1.6;}

  .food-card{background:white;border-radius:16px;overflow:hidden;box-shadow:var(--shadow);cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;position:relative;border:2px solid transparent;}
  .food-card.selected{border-color:var(--orange);box-shadow:0 4px 20px rgba(255,107,0,0.35);transform:scale(1.03);}
  .food-img{width:100%;height:110px;display:flex;align-items:center;justify-content:center;font-size:50px;background:linear-gradient(135deg,#FFF0E0,#FFD9B0);position:relative;}
  .veg-dot{position:absolute;top:6px;left:6px;width:14px;height:14px;border-radius:50%;border:2px solid;}
  .veg-dot.veg{background:#16A34A;border-color:#166534;}
  .veg-dot.nonveg{background:#DC2626;border-color:#991B1B;}
  .food-info{padding:10px 10px 12px;}
  .food-name{font-size:13px;font-weight:700;line-height:1.3;}
  .food-desc{font-size:10px;color:#999;margin-top:2px;font-style:italic;}
  .food-price{font-size:15px;font-weight:800;color:var(--orange);margin-top:4px;}
  .food-check{position:absolute;top:8px;right:8px;width:28px;height:28px;background:var(--orange);color:white;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:16px;}
  .food-card.selected .food-check{display:flex;}
  .qty-sel{display:none;align-items:center;justify-content:space-between;background:#FFF0E0;border-radius:8px;margin-top:6px;padding:4px 6px;}
  .food-card.selected .qty-sel{display:flex;}
  .qty-btn{width:26px;height:26px;background:var(--orange);color:white;border:none;border-radius:6px;font-size:16px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .qty-num{font-weight:700;font-size:15px;}

  .cart-bar{display:none;position:fixed;bottom:70px;left:12px;right:12px;background:var(--orange);color:white;border-radius:16px;padding:14px 18px;align-items:center;justify-content:space-between;box-shadow:0 8px 30px rgba(255,107,0,0.5);z-index:100;cursor:pointer;}
  .cart-bar.show{display:flex;}
  .cl{font-size:14px;font-weight:700;}
  .cl span{font-size:12px;font-weight:400;opacity:.9;display:block;}
  .cr{background:white;color:var(--orange);font-weight:800;font-size:14px;padding:8px 16px;border-radius:10px;}

  .order-sec{background:white;margin:0 12px 16px;border-radius:20px;padding:20px;box-shadow:var(--shadow);}
  .form-title{font-size:16px;font-weight:800;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
  .fg{margin-bottom:14px;}
  .fg label{font-size:12px;font-weight:600;color:#666;display:block;margin-bottom:6px;}
  .fg input,.fg textarea{width:100%;padding:12px 14px;border:2px solid #EEE;border-radius:12px;font-size:14px;font-family:inherit;outline:none;background:#FAFAFA;color:var(--dark);transition:border .2s;}
  .fg input:focus,.fg textarea:focus{border-color:var(--orange);background:white;}
  .fg textarea{resize:none;height:70px;}

  .order-summary{background:#FFF8F0;border-radius:12px;padding:14px;margin-bottom:16px;display:none;}
  .order-summary.show{display:block;}
  .sum-title{font-size:13px;font-weight:700;margin-bottom:10px;color:#555;}
  .sum-item{display:flex;justify-content:space-between;font-size:13px;padding:4px 0;border-bottom:1px dashed #EDD;}
  .sum-total{display:flex;justify-content:space-between;font-size:16px;font-weight:800;color:var(--orange);margin-top:8px;padding-top:8px;border-top:2px solid #FFD0A0;}

  .delivery-reminder{background:linear-gradient(135deg,#FFF3CD,#FFF8E0);border:2px solid var(--yellow);border-radius:12px;padding:12px 14px;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
  .dr-icon{font-size:24px;}
  .dr-text{font-size:12px;font-weight:700;color:#7A3000;line-height:1.6;}

  .loc-box{border:2px dashed #DDD;border-radius:14px;padding:16px;text-align:center;background:#FAFAFA;transition:all .3s;}
  .loc-box.got{border-color:#4CAF50;background:#F0FFF4;border-style:solid;}
  .loc-box.err{border-color:#E53935;background:#FFF5F5;border-style:solid;}
  .loc-title{font-size:14px;font-weight:700;margin-top:6px;}
  .loc-sub{font-size:11px;color:#888;margin-top:4px;}
  .loc-btn{display:inline-flex;align-items:center;gap:6px;background:var(--orange);color:white;border:none;border-radius:10px;padding:10px 18px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;margin-top:10px;transition:background .2s;}
  .loc-btn.got{background:#4CAF50;}
  .loc-coords{font-size:11px;color:#4CAF50;font-weight:600;margin-top:6px;}
  .loc-map-link{margin-top:6px;}
  .loc-map-link a{font-size:12px;color:var(--gpay);text-decoration:none;font-weight:600;}

  .pay-opts{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
  .pay-card{border:2px solid #EEE;border-radius:12px;padding:14px 10px;text-align:center;cursor:pointer;transition:all .2s;}
  .pay-card.selected{border-color:var(--orange);background:#FFF5EE;}
  .pi{font-size:28px;}.pn{font-size:12px;font-weight:700;margin-top:4px;}.pd{font-size:10px;color:#888;margin-top:2px;}

  .gpay-sec{display:none;background:#E8F0FE;border-radius:12px;padding:14px;margin-bottom:14px;text-align:center;}
  .gpay-sec.show{display:block;}
  .gpay-link{display:inline-flex;align-items:center;gap:8px;background:var(--gpay);color:white;font-weight:700;font-size:15px;padding:12px 24px;border-radius:12px;text-decoration:none;margin-top:10px;}
  .gpay-note{font-size:11px;color:#555;margin-top:8px;}

  .submit-btn{width:100%;padding:16px;background:linear-gradient(135deg,var(--orange),#FF9A00);color:white;border:none;border-radius:14px;font-size:16px;font-weight:800;font-family:inherit;cursor:pointer;box-shadow:0 6px 20px rgba(255,107,0,0.4);}
  .submit-btn:disabled{background:#CCC;box-shadow:none;cursor:not-allowed;}

  .success-screen{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;align-items:center;justify-content:center;padding:20px;}
  .success-screen.show{display:flex;}
  .success-box{background:white;border-radius:24px;padding:28px 22px;text-align:center;max-width:320px;width:100%;animation:popIn .3s ease;}
  @keyframes popIn{from{transform:scale(.8);opacity:0}to{transform:scale(1);opacity:1}}
  .si{font-size:56px;}.st{font-size:20px;font-weight:800;color:var(--green);margin-top:8px;}
  .so{background:#F0FFF4;border:2px dashed var(--green);border-radius:12px;padding:10px;margin:12px 0;font-weight:800;color:var(--green);font-size:15px;}
  .sm{font-size:12px;color:#555;line-height:1.7;}
  .sm .del-highlight{display:inline-block;background:var(--yellow);color:#7A3000;font-weight:800;padding:4px 12px;border-radius:8px;margin-top:8px;font-size:13px;}
  .s-wa{display:block;background:var(--green);color:white;border-radius:12px;padding:12px;font-weight:700;text-decoration:none;margin-top:14px;}
  .s-close{background:var(--orange);color:white;border:none;border-radius:12px;padding:12px 30px;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;width:100%;margin-top:8px;}

  .loading{display:none;position:fixed;inset:0;background:rgba(255,255,255,0.88);z-index:300;flex-direction:column;align-items:center;justify-content:center;gap:12px;}
  .loading.show{display:flex;}
  .spinner{width:48px;height:48px;border:5px solid #FFD0A0;border-top-color:var(--orange);border-radius:50%;animation:spin .8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg)}}
  .loading p{font-weight:700;color:var(--orange);font-size:14px;}

  .footer{background:var(--dark);color:rgba(255,255,255,0.65);text-align:center;padding:20px;font-size:12px;padding-bottom:90px;}
  .footer a{color:var(--yellow);text-decoration:none;font-weight:600;}
</style>
</head>
<body>

<div class="header">
  <h1>🍱 KRK's Kitchen</h1>
  <p class="tagline">Fresh Home Food | Daily Dinner Orders</p>
  <a class="call-btn" href="tel:+916384991641">📞 Call: 63849 91641</a>
</div>

<div class="delivery-banner">
  <div class="del-icon">🛵</div>
  <div class="del-info">
    <div class="del-title">Order Morning-ல் பண்ணுங்கள்!</div>
    <div class="del-note">காலையிலிருந்து orders எடுக்கிறோம்<br>Delivery: Evening-ல் மட்டும்</div>
  </div>
  <div class="del-timebox">
    <div class="del-time">7:30–9:30 PM</div>
    <div class="del-label">DELIVERY</div>
  </div>
</div>

<div class="last-order-strip">
  <span class="lo-icon">⏰</span>
  <span class="lo-text">Order இன்று <strong>5:00 PM</strong> க்கு முன் பண்ணுங்கள்</span>
  <span class="lo-time">Cutoff: 5 PM</span>
</div>

<div class="marquee-bar"><span>🌿 Fresh home food daily 🍱 Order anytime — Delivery: 7:30 PM – 9:30 PM 🛵 Order before 5:00 PM ✅ KRK's Kitchen</span></div>

<div class="section-title">
  🍽️ Today's Dinner Menu
  <span class="menu-date-badge" id="menu-date-badge">Today</span>
</div>
<div class="menu-grid" id="menu-grid"></div>
<div class="no-menu" id="no-menu" style="display:none;">
  <div class="nm-icon">📋</div>
  <div class="nm-title">Today's menu இன்னும் ready ஆகவில்லை</div>
  <div class="nm-sub">சற்று நேரத்தில் WhatsApp Status பாருங்கள்<br>அல்லது call பண்ணுங்கள்: 63849 91641</div>
</div>

<div class="order-sec" id="order-form-section">
  <div class="form-title">📋 Place Your Order</div>

  <div class="order-summary" id="order-summary">
    <div class="sum-title">🛒 Your Items:</div>
    <div id="sum-items"></div>
    <div class="sum-total"><span>Total:</span><span id="sum-total">₹0</span></div>
  </div>

  <div class="delivery-reminder">
    <div class="dr-icon">🕐</div>
    <div class="dr-text">உங்கள் order இன்று evening<br><strong>7:30 PM – 9:30 PM</strong> க்குள் deliver ஆகும் 🛵</div>
  </div>

  <div class="fg">
    <label>👤 Your Name *</label>
    <input type="text" id="cust-name" placeholder="உங்கள் பெயர்"/>
  </div>
  <div class="fg">
    <label>📱 WhatsApp Number *</label>
    <input type="tel" id="cust-phone" placeholder="9XXXXXXXXX" maxlength="10"/>
  </div>
  <div class="fg">
    <label>🏠 Delivery Address *</label>
